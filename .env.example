# --- Required ---
SESSION_SECRET=change-me-to-a-32+char-random-string

# --- Paths (defaults work for local dev; docker-compose overrides) ---
DB_URL=sqlite+aiosqlite:///./data/bek.db
MODELS_DIR=./models
DATA_DIR=./data

# --- InsightFace execution providers ---
# GPU prod:  CUDAExecutionProvider,CPUExecutionProvider
# Mac dev:   CoreMLExecutionProvider,CPUExecutionProvider
# CPU only:  CPUExecutionProvider
EXECUTION_PROVIDERS=CUDAExecutionProvider,CPUExecutionProvider

# --- Recognition thresholds (env-overridable, see plan §Recognition pipeline) ---
RECOGNITION_THRESHOLD_STRONG=0.60
RECOGNITION_THRESHOLD_SOFT=0.50
ANTISPOOF_THRESHOLD=0.80

# --- Debounce (server-side stabilization) ---
DEBOUNCE_WINDOW_MS=2500
DEBOUNCE_REQUIRED=3
DEBOUNCE_OF=5

# --- Kiosk / admin ---
KIOSK_TIMEOUT_S=10
ADMIN_SESSION_TTL_HOURS=8
PENDING_TOKEN_TTL_S=15

# --- Snapshot retention ---
SNAPSHOT_RETENTION_DAYS=90

# --- Timezone (restaurant local) ---
RESTAURANT_TZ=Asia/Tashkent

# --- "Shift day" boundary for cross-midnight shifts ---
# Events between 00:00 and this hour count toward the previous calendar day.
SHIFT_DAY_CUTOFF_HOUR=4
