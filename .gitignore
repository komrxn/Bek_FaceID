# Runtime data — keep the folder shape, ignore all contents.
data/*
!data/.gitkeep

# Models (downloaded by scripts/download_models.sh)
models/buffalo_l/
models/silent_face/

# Secrets
.env
backend/.env
frontend/.env
frontend/.env.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
dist/
.vite/

# IDE / OS
.DS_Store
.idea/
.vscode/
.claude/

# Logs
*.log

# Capacitor Android build artifacts (manifest project tree is committed,
# build outputs are not — Capacitor's own android/.gitignore covers most
# of it, this is just the belt-and-suspenders).
frontend/android/.gradle/
frontend/android/app/build/
frontend/android/build/
frontend/android/local.properties
frontend/android/captures/
frontend/android/.idea/
frontend/android/*.iml

# Hand-off APK (built artifact, not source). Re-build with `npm run app:apk`.
*.apk

# Rasterized icon/splash sources — regenerated by scripts/rasterize-icons.mjs
frontend/resources/icon.png
frontend/resources/splash.png
frontend/resources/splash-dark.png
